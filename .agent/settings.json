{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .agent/hooks/gsd-check-update.js"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .agent/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ],
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task"
      }
    ],
    "BeforeTool": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .agent/hooks/gsd-prompt-guard.js",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
